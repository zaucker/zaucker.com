---
import type { Locale } from '@/lib/types';
import Layout from '@/layouts/Layout.astro';
import ApartmentCard from '@/components/ApartmentCard.astro';
import { Image } from 'astro:assets';
import introPhoto from '../../assets/home/intro.jpg';
import { t } from '@/lib/i18n';
import { getVisibleApartments } from '@/lib/apartments';
import { pagePath } from '@/lib/routes';
import { getEntry } from 'astro:content';

const locale: Locale = 'en';
const page = await getEntry('pages', 'en/home');
const intro = page!.data.intro ?? [];
const accents = ['bg-lake/12 text-lake', 'bg-alpine/15 text-alpine', 'bg-sun/15 text-sun', 'bg-lake/12 text-lake'];
const apartments = getVisibleApartments();
const apartmentBodies = import.meta.glob('/src/content/en/apartments/*.md', { eager: true }) as Record<string, any>;
function aptMeta(apt: typeof apartments[number]) {
  const mod = apartmentBodies[`/src/content/en/apartments/${apt.slug.en}.md`];
  return { title: mod.frontmatter.title as string };
}
---
<Layout locale={locale} title={page!.data.title} description={page!.data.description ?? ''} currentPath="/en/" altHref="/" isHome>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <section class="pt-10 pb-14 lg:pt-14">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
        <div>
          <h1 class="reveal font-display text-4xl sm:text-5xl font-semibold text-ink leading-[1.05] tracking-tight">Apt Zaucker</h1>
          <ul class="mt-8 space-y-4">
            {intro.map((item, i) => (
              <li class="reveal flex items-start gap-4" style={`animation-delay:${140 + i * 90}ms`}>
                <span class={`flex-shrink-0 grid place-items-center w-11 h-11 rounded-full text-xl ${accents[i % accents.length]}`} aria-hidden="true">{item.icon}</span>
                <p class="text-stone-700 leading-relaxed pt-1.5">{item.text}</p>
              </li>
            ))}
          </ul>
        </div>
        <div class="reveal relative" style="animation-delay:80ms">
          <div class="absolute -right-4 -bottom-4 w-full h-full rounded-3xl bg-lake/15 hidden sm:block"></div>
          <Image src={introPhoto} alt="View from the Zaucker holiday apartments over Überlingen, Lake Constance and the Alps" widths={[480, 800, 1100]} sizes="(min-width: 1024px) 45vw, 100vw" class="relative rounded-3xl shadow-xl ring-1 ring-black/5 w-full aspect-[4/3] object-cover" />
        </div>
      </div>
    </section>
    <section class="pt-8 pb-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {apartments.map(apt => { const m = aptMeta(apt); return <ApartmentCard apt={apt} locale={locale} title={m.title} />; })}
      </div>
      <div class="mt-10 text-center">
        <a href={pagePath(locale, 'availability')} class="inline-block px-8 py-4 rounded-xl bg-lake text-white text-lg font-semibold hover:bg-lake-dark transition-colors shadow-lg shadow-lake/30">{t(locale, 'nav_check_availability')}</a>
      </div>
    </section>
  </div>
</Layout>
