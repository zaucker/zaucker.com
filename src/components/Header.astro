---
import type { Locale } from '@/lib/types';
import { getNav } from '@/lib/routes';
interface Props { locale: Locale; currentPath: string; altHref: string | null; }
const { locale, currentPath, altHref } = Astro.props;
const nav = getNav(locale);
const switchLabel = locale === 'de' ? 'English' : 'Deutsch';
const otherLang = locale === 'de' ? 'en' : 'de';
const menuLabel = locale === 'de' ? 'Menü öffnen' : 'Open menu';
const norm = (p: string) => (p === '/' ? '/' : p.replace(/\/$/, ''));
const isActive = (href: string) => norm(currentPath) === norm(href);
---
<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-stone-100 shadow-sm">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16">
      <div class="hidden md:flex items-center gap-1">
        {nav.map(item => (
          <a href={item.href}
             class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${isActive(item.href) ? 'text-lake bg-lake/10' : 'text-stone-700 hover:text-lake hover:bg-stone-50'}`}>
            {item.label}
          </a>
        ))}
      </div>
      {altHref && (
        <a href={altHref} hreflang={otherLang}
           class="hidden md:inline-block px-3 py-1.5 rounded border border-stone-200 text-sm text-stone-600 hover:border-lake hover:text-lake transition-colors">
          {switchLabel}
        </a>
      )}
      <button id="mobile-menu-btn" class="md:hidden ml-auto p-2 rounded-md text-stone-600 hover:text-lake"
              aria-expanded="false" aria-controls="mobile-menu" aria-label={menuLabel}>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden pb-3 border-t border-stone-100">
      {nav.map(item => (
        <a href={item.href} class="block px-3 py-2 text-sm font-medium text-stone-700 hover:text-lake hover:bg-stone-50 rounded-md">
          {item.label}
        </a>
      ))}
      {altHref && <a href={altHref} hreflang={otherLang} class="block px-3 py-2 text-sm text-stone-500">{switchLabel}</a>}
    </div>
  </nav>
</header>
