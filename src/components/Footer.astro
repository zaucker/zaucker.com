---
import type { Locale } from '@/lib/types';
import { pagePath } from '@/lib/routes';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const links = [
  { label: locale === 'de' ? 'Kontakt' : 'Contact', href: pagePath(locale, 'contact') },
  { label: locale === 'de' ? 'Impressum' : 'Legal Notice', href: pagePath(locale, 'impressum') },
  { label: locale === 'de' ? 'Datenschutz' : 'Privacy Policy', href: pagePath(locale, 'datenschutz') },
];
---
<footer class="shrink-0 bg-lake text-white/85">
  <nav class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 h-11 flex items-center justify-center gap-5 sm:gap-8 text-sm"
       aria-label="Footer">
    {links.map(l => (
      <a href={l.href} class="hover:text-white transition-colors">{l.label}</a>
    ))}
  </nav>
</footer>
