---
import type { Apartment, Locale } from '@/lib/types';
import { t } from '@/lib/i18n';
import { apartmentPath } from '@/lib/routes';
interface Props { apt: Apartment; locale: Locale; title: string; }
const { apt, locale, title } = Astro.props;
const href = apartmentPath(locale, apt);
const seasons = apt.pricing.seasons;
const minRate = seasons[seasons.length - 1].rate_per_day;
const maxRate = seasons[0].rate_per_day;
---
<article class="rounded-2xl border border-stone-200 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition duration-300 bg-white">
  <div class="h-1.5 bg-gradient-to-r from-lake via-sun to-alpine"></div>
  <div class="p-6">
    <div class="flex flex-wrap gap-2 mb-3">
      <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-stone-100 text-stone-700">{apt.specs.bedrooms} {t(locale, 'section_bedrooms')}</span>
      <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-stone-100 text-stone-700">{t(locale, 'unit_up_to')} {apt.specs.max_guests} {t(locale, 'unit_persons')}</span>
      {apt.specs.area_m2 && <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-stone-100 text-stone-700">ca. {apt.specs.area_m2} m²</span>}
    </div>
    <h2 class="text-xl font-semibold text-stone-900 mb-4"><a href={href} class="hover:text-lake transition-colors">{title}</a></h2>
    <div class="flex items-center justify-between">
      <div class="text-sm text-stone-500">{t(locale, 'nav_from')} <span class="text-lg font-bold text-stone-900">€{minRate}</span> – €{maxRate} {t(locale, 'price_per_day')}</div>
      <a href={href} class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-lake text-white text-sm font-medium hover:bg-lake-dark transition-colors">
        {t(locale, 'nav_details')}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </a>
    </div>
  </div>
</article>
